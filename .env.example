# ─── 투자 분석 Agent 환경변수 템플릿 ───
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요.
#   cp .env.example .env
# 주의: .env 는 절대 커밋·공유 금지 (.gitignore 로 보호됨)

# ── 무료 API 키 4종 (Phase 0에서 발급) ──
# DART 오픈API — 한국 공시·국민연금 5%·임원 지분변동  (https://opendart.fss.or.kr)
DART_API_KEY=
# k-dart 스킬 전용 별칭 — 위 DART_API_KEY 와 동일 값을 넣으세요 (스킬이 이 이름을 읽음)
API_K_DART=

# (불채택 2026-07-07) 공공데이터포털 — data.go.kr에 국민연금 주식 보유 API 부재.
# 국민연금 5% 지분은 DART(k-dart)로 커버하므로 이 키는 발급 불필요.

# FRED — 미 금리·인플레·경제지표  (https://fred.stlouisfed.org)
FRED_API_KEY=

# Congress.gov — 미 법안 추적  (https://api.congress.gov/sign-up)
CONGRESS_GOV_API_KEY=

# ── 키 불필요 소스용 필수 헤더 ──
# SEC EDGAR 는 키는 없지만 User-Agent 헤더가 필수 (이름/이메일 형식 권장)
SEC_USER_AGENT="Investment Analysis Agent vrotoss@gmail.com"

# ── 알림 (Phase 0 훅에서 재활용) ──
# 기존 다모다란 텔레그램 봇 토큰 재사용 — 분석 완료 시 알림 발송
TELEGRAM_BOT_TOKEN=
# 알림 받을 채팅 ID (본인 계정) — @userinfobot 에게 말 걸면 확인 가능
TELEGRAM_CHAT_ID=

# ── 웹 (Phase 2~4) ──
# 프론트↔백엔드 공유 비밀키 1개 (아무 긴 랜덤 문자열)
APP_SHARED_SECRET=
# 프론트(Vercel) 도메인 — CORS 허용 대상 (배포 후 채움)
ALLOWED_ORIGIN=

# ─── 다모다란 기업분석 텔레그램 봇 설정 ───
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요.
# cp .env.example .env

# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=여기에_텔레그램_봇_토큰_입력

# Anthropic API 키
ANTHROPIC_API_KEY=여기에_API_키_입력

# Claude 모델 (선택사항, 기본값: claude-sonnet-4-20250514)
# 더 깊은 분석 원할 시 claude-opus-4-20250514 사용 가능
CLAUDE_MODEL=claude-sonnet-4-20250514

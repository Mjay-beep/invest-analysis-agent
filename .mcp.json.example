{
  "//": "채택 MCP 2종 (설계서 §10-1). 한국 DART 는 MCP 대신 k-dart 스킬(.claude/skills/k-dart)로 대체(2026-07-07 결정) — 여기 없음. 키 발급·검증 후 이 파일을 .mcp.json 으로 복사해 사용. 키는 .env 에서 주입되며 이 파일에 직접 쓰지 않는다.",

  "mcpServers": {
    "sec-edgar": {
      "//": "13F·Form 4·미국 재무제표. 키 불필요, SEC_USER_AGENT 헤더만 필요. 정확한 실행 커맨드는 설치 시 리포지토리(stefanoamorelli/sec-edgar-mcp) README로 확정.",
      "command": "uvx",
      "args": ["sec-edgar-mcp"],
      "env": {
        "SEC_EDGAR_USER_AGENT": "${SEC_USER_AGENT}"
      }
    },

    "fred": {
      "//": "연준 경제지표 시계열. FRED_API_KEY 필요. (stefanoamorelli/fred-mcp-server)",
      "command": "uvx",
      "args": ["fred-mcp-server"],
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}"
      }
    }
  }
}
